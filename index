function pack(arr, subjCode, subjName, prefix){
  arr.forEach((a,i)=>{
    Q.push({
      id: prefix+(i+1),
      subj: subjCode,
      subjName: subjName,
      text: a[0],
      options: a[1],
      correct: a[2],
      explain: a[3]
    });
  });
}
pack(rtos,"RTOS","Real-Time Operating Systems","R");
pack(iot,"IOT","Internet of Things","I");
pack(edd,"EDD","Embedded Device Drivers","D");
pack(apt,"APT","Aptitude","A");

/* ===================== STATE ===================== */
const TOTAL = Q.length;
let state = {
  current: 0,
  answers: new Array(TOTAL).fill(null),
  marked: new Array(TOTAL).fill(false),
  visited: new Array(TOTAL).fill(false),
};
let instantFeedback = false;
let timeLeft = 60*60;
let timerHandle = null;

/* ===================== DOM REFS ===================== */
const startScreen = document.getElementById('startScreen');
const examScreen = document.getElementById('examScreen');
const resultScreen = document.getElementById('resultScreen');
const startBtn = document.getElementById('startBtn');
const qTag = document.getElementById('qTag');
const qPos = document.getElementById('qPos');
const qText = document.getElementById('qText');
const qOptions = document.getElementById('qOptions');
const qReveal = document.getElementById('qReveal');
const prevBtn = document.getElementById('prevBtn');
const nextBtn = document.getElementById('nextBtn');
const clearBtn = document.getElementById('clearBtn');
const markBtn = document.getElementById('markBtn');
const submitBtn = document.getElementById('submitBtn');
const navGrid = document.getElementById('navGrid');
const timerVal = document.getElementById('timerVal');
const metaAnswered = document.getElementById('metaAnswered');
const metaMarked = document.getElementById('metaMarked');
const metaUnanswered = document.getElementById('metaUnanswered');

/* ===================== START ===================== */
startBtn.addEventListener('click', ()=>{
  instantFeedback = document.getElementById('instantFeedback').checked;
  startScreen.classList.add('hidden');
  examScreen.classList.remove('hidden');
  buildNavGrid();
  renderQuestion();
  startTimer();
});

/* ===================== TIMER ===================== */
function startTimer(){
  timerHandle = setInterval(()=>{
    timeLeft--;
    if(timeLeft<=0){ clearInterval(timerHandle); timeLeft=0; finishTest(); }
    const m = Math.floor(timeLeft/60).toString().padStart(2,'0');
    const s = (timeLeft%60).toString().padStart(2,'0');
    timerVal.textContent = m+':'+s;
  },1000);
}

/* ===================== RENDER QUESTION ===================== */
function renderQuestion(){
  const i = state.current;
  const q = Q[i];
  state.visited[i] = true;
  qTag.textContent = q.subjName.split(' ').slice(0,2).join(' ');
  qTag.className = 'tag tag-'+q.subj;
  qPos.textContent = 'Question '+(i+1)+' of '+TOTAL+'  ·  '+q.subjName;
  qText.textContent = q.text;
  qOptions.innerHTML = '';
  const labels = ['A','B','C','D'];
  q.options.forEach((opt,idx)=>{
    const div = document.createElement('label');
    div.className = 'opt'+(state.answers[i]===idx?' selected':'');
    div.innerHTML = '<input type="radio" name="opt" '+(state.answers[i]===idx?'checked':'')+'><span class="lab">'+labels[idx]+'.</span><span>'+opt+'</span>';
    div.addEventListener('click', ()=>{
      state.answers[i] = idx;
      renderQuestion();
      if(instantFeedback) showReveal(q, idx);
    });
    qOptions.appendChild(div);
  });
  qReveal.className = 'reveal';
  qReveal.innerHTML = '';
  if(instantFeedback && state.answers[i]!==null){ showReveal(q, state.answers[i]); }
  markBtn.textContent = state.marked[i] ? 'Unmark Review' : 'Mark for Review';
  prevBtn.disabled = i===0;
  nextBtn.textContent = i===TOTAL-1 ? 'Finish' : 'Save & Next →';
  updateNavGrid();
  updateMeta();
}
function showReveal(q, chosenIdx){
  const correct = chosenIdx===q.correct;
  qReveal.className = 'reveal show '+(correct?'correct':'wrong');
  qReveal.innerHTML = (correct ? '✓ Correct. ' : '✗ Incorrect — correct answer is '+['A','B','C','D'][q.correct]+'. ') + q.explain;
}

/* ===================== NAV GRID ===================== */
function buildNavGrid(){
  navGrid.innerHTML = '';
  for(let i=0;i<TOTAL;i++){
    const b = document.createElement('button');
    b.className = 'navBtn';
    b.textContent = i+1;
    b.addEventListener('click', ()=>{ state.current=i; renderQuestion(); });
    navGrid.appendChild(b);
  }
}
function updateNavGrid(){
  const btns = navGrid.children;
  for(let i=0;i<TOTAL;i++){
    const b = btns[i];
    b.className = 'navBtn';
    const answered = state.answers[i]!==null;
    const marked = state.marked[i];
    if(answered && marked) b.classList.add('answeredmarked');
    else if(marked) b.classList.add('marked');
    else if(answered) b.classList.add('answered');
    if(i===state.current) b.classList.add('current');
  }
}
function updateMeta(){
  const answered = state.answers.filter(a=>a!==null).length;
  const marked = state.marked.filter(Boolean).length;
  metaAnswered.textContent = answered+' / '+TOTAL;
  metaMarked.textContent = marked;
  metaUnanswered.textContent = TOTAL-answered;
}

/* ===================== CONTROLS ===================== */
clearBtn.addEventListener('click', ()=>{ state.answers[state.current]=null; renderQuestion(); });
markBtn.addEventListener('click', ()=>{ state.marked[state.current]=!state.marked[state.current]; renderQuestion(); });
prevBtn.addEventListener('click', ()=>{ if(state.current>0){ state.current--; renderQuestion(); } });
nextBtn.addEventListener('click', ()=>{
  if(state.current<TOTAL-1){ state.current++; renderQuestion(); }
  else { finishTest(); }
});
document.querySelectorAll('[data-jump]').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    const subj = btn.getAttribute('data-jump');
    const idx = Q.findIndex(q=>q.subj===subj);
    state.current = idx;
    renderQuestion();
  });
});
submitBtn.addEventListener('click', ()=>{
  if(confirm('Submit the test? You will not be able to change answers afterward.')) finishTest();
});

/* ===================== RESULTS ===================== */
function finishTest(){
  clearInterval(timerHandle);
  examScreen.classList.add('hidden');
  resultScreen.classList.remove('hidden');

  let correct=0, attempted=0;
  const bySubj = {RTOS:{c:0,t:0},IOT:{c:0,t:0},EDD:{c:0,t:0},APT:{c:0,t:0}};
  Q.forEach((q,i)=>{
    bySubj[q.subj].t++;
    if(state.answers[i]!==null){
      attempted++;
      if(state.answers[i]===q.correct){ correct++; bySubj[q.subj].c++; }
    }
  });
  const pct = Math.round((correct/TOTAL)*100);

  document.getElementById('resultGrid').innerHTML = `
    <div class="scoreCard"><div class="big">${correct} / ${TOTAL}</div><div class="lbl">Correct Answers</div><div class="bar"><div style="width:${pct}%"></div></div></div>
    <div class="scoreCard"><div class="big">${attempted} / ${TOTAL}</div><div class="lbl">Attempted</div></div>
    <div class="scoreCard"><div class="big">${pct}%</div><div class="lbl">Overall Score</div></div>
    <div class="scoreCard"><div class="big">${60-Math.floor(timeLeft/60)}m ${(60*60-timeLeft)%60}s</div><div class="lbl">Time Taken</div></div>
  `;

  const names = {RTOS:'RTOS',IOT:'IoT',EDD:'Drivers',APT:'Aptitude'};
  document.getElementById('subjectGrid').innerHTML = Object.keys(bySubj).map(k=>{
    const s=bySubj[k]; const p=Math.round((s.c/s.t)*100);
    return `<div class="scoreCard"><div class="big">${s.c}/${s.t}</div><div class="lbl">${names[k]}</div><div class="bar"><div style="width:${p}%"></div></div></div>`;
  }).join('');

  document.getElementById('reviewBtn').onclick = ()=>{
    const rl = document.getElementById('reviewList');
    rl.classList.toggle('hidden');
    if(!rl.dataset.built){
      rl.innerHTML = Q.map((q,i)=>{
        const chosen = state.answers[i];
        const isCorrect = chosen===q.correct;
        const labels=['A','B','C','D'];
        return `<div class="reviewItem">
          <div class="q">${i+1}. [${names[q.subj]}] ${q.text}</div>
          <div class="a">Your answer: <b class="${chosen===null?'':(isCorrect?'ok':'bad')}">${chosen===null?'Not attempted':labels[chosen]+'. '+q.options[chosen]}</b></div>
          <div class="a">Correct answer: <b class="ok">${labels[q.correct]}. ${q.options[q.correct]}</b></div>
          <div class="a" style="color:#6b6557;">${q.explain}</div>
        </div>`;
      }).join('');
      rl.dataset.built = '1';
    }
  };
  document.getElementById('retakeBtn').onclick = ()=> location.reload();
}
</script>
